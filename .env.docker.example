# ===========================================================================
# Synthetic User Lab 容器化环境变量样例
# 用法：cp .env.docker.example .env，只需填模型配置即可启动。
#   docker compose up -d      # 访问 http://localhost:8765
# 说明：host/database_url/frontend_dir 由 docker-compose.yml 注入，此处无需填写。
# ===========================================================================

# ---- 模型 Provider 选择 ----
# 可选 openai（兼容 OpenAI 接口）或 dashscope（阿里百炼）
MODEL_PROVIDER=openai

# ---- OpenAI 兼容配置（MODEL_PROVIDER=openai 时使用）----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_NAME=gpt-4o
OPENAI_FAST_MODEL_NAME=gpt-4o-mini

# ---- 阿里百炼配置（MODEL_PROVIDER=dashscope 时使用）----
# DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# DASHSCOPE_MODEL_NAME=qwen-plus
# DASHSCOPE_FAST_MODEL_NAME=qwen-turbo
# DASHSCOPE_BASE_URL=

# ---- 浏览器无头运行（容器内建议 true）----
SYNTHETIC_USER_LAB_HEADLESS=true

# ---- 可选：自定义系统提示词 ----
CUSTOM_SYSTEM_PROMPT=
