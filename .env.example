# ===========================================================================
# Synthetic User Lab 环境变量样例
# 用法：cp .env.example .env，然后填入你自己的模型 API Key 即可启动。
#   npm install        # 安装根级 concurrently（一键启动前后端）
#   uv sync --extra dev
#   uv run python -m playwright install
#   cd frontend && npm install
#   npm run dev        # 访问 http://localhost:5173
# ===========================================================================

# ---- 服务配置 ----
SYNTHETIC_USER_LAB_APP_NAME=Synthetic User Lab
SYNTHETIC_USER_LAB_ENV=development
SYNTHETIC_USER_LAB_API_PREFIX=/api/v1
# 后端监听地址与端口（npm run dev 默认用 8765）
SYNTHETIC_USER_LAB_HOST=127.0.0.1
SYNTHETIC_USER_LAB_PORT=8765
# 注意：BASE_URL 必须与实际监听端口一致，否则 MVP 样例 task 的 start_url 会指向错误端口，
# 导致 Playwright 打不开测试站点。npm run dev 启动后端在 8765，故此处用 8765。
SYNTHETIC_USER_LAB_BASE_URL=http://127.0.0.1:8765
# 浏览器是否无头运行（true=无头；调试可设 false 看浏览器窗口）
SYNTHETIC_USER_LAB_HEADLESS=true
# 单次 run 最大步数上限（per-run 可通过 max_steps_override 覆盖）
SYNTHETIC_USER_LAB_RUN_STEP_LIMIT=8
# 持久化后端：:memory:（内存，重启丢失）/ SQLite 文件路径 / PostgreSQL DSN
# 默认 SQLite：data/synthetic_user_lab.db
# PostgreSQL 示例：postgresql://user:pass@localhost:5432/synthetic_user_lab
SYNTHETIC_USER_LAB_DATABASE_URL=data/synthetic_user_lab.db
# 前端开发服务器地址（CORS 白名单，逗号分隔）
SYNTHETIC_USER_LAB_CORS_ORIGINS=http://localhost:5173

# ---- 模型 Provider 选择 ----
# 可选 openai（兼容 OpenAI 接口）或 dashscope（阿里百炼）
# 下方只需填写你选定 provider 对应的配置块
MODEL_PROVIDER=openai

# ---- OpenAI 兼容配置（MODEL_PROVIDER=openai 时使用）----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_NAME=gpt-4o
OPENAI_FAST_MODEL_NAME=gpt-4o-mini

# ---- 阿里百炼配置（MODEL_PROVIDER=dashscope 时使用）----
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_MODEL_NAME=qwen-plus
DASHSCOPE_FAST_MODEL_NAME=qwen-turbo
# 可选：自定义百炼网关地址，留空走默认
DASHSCOPE_BASE_URL=

# ---- 可选：自定义系统提示词（追加到 agent system prompt）----
CUSTOM_SYSTEM_PROMPT=
